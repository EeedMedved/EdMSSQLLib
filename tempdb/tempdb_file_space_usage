-- Вариант 1 в контексте любой БД

SELECT used_percent = ((SUM(total_page_count) - SUM(unallocated_extent_page_count)) * 100.0) / SUM(total_page_count)
FROM tempdb.sys.dm_db_file_space_usage;

-- Вариант 2 в контексте tempdb
WITH TempdbSpaceUsage AS (
    SELECT
        SUM(size * 8.0) AS TotalSpaceKB,
        SUM(CAST(FILEPROPERTY(name, 'SpaceUsed') AS BIGINT) * 8.0) AS UsedSpaceKB
    FROM
        sys.master_files
    WHERE
        database_id = DB_ID('tempdb')
        AND type_desc = 'ROWS'
)
SELECT
    ((UsedSpaceKB / TotalSpaceKB) * 100.0) AS [Usage Percent]
FROM
    TempdbSpaceUsage;